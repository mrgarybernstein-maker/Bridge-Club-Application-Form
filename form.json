      "label": "Day",
      "type": "checkbox",
      "required": true,
      "options": [
        {
          "value": "monday",
          "label": "Monday",
          "required": false
        },
        {
          "value": "wednesday",
          "label": "Wednesday",
          "required": false
        },
        {
          "value": "friday",
          "label": "Friday",
          "required": false
        }
      ]
    },
    {
      "id": "acbl",
      "label": "ACBL number",
      "type": "split",
      "pattern": "ANNNNNNN",
      "required": true
