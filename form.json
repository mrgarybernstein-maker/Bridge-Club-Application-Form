      "options": [
        {
          "value": "novice",
          "label": "Novice"
        },
        {
          "value": "intermediate",
          "label": "Intermediate"
        },
        {
          "value": "advanced",
          "label": "Advanced"
        },
        {
          "value": "expert",
          "label": "Expert"
        }
      ]
    },
    {
      "id": "time",
