      "options": [
        {
          "value": "evening",
          "label": "Evening",
          "required": false
        },
        {
          "value": "afternoon",
          "label": "Afternoon",
          "required": false
        },
        {
          "value": "morning",
          "label": "Morning",
          "required": false
        }
      ]
    },
    {
